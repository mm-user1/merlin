{
  "id": "s03_reversal_v11_regime_er_b2",
  "name": "S03 Reversal v11 Regime-ER B2",
  "version": "v11-regime-er-b2",
  "engine": "v2",
  "description": "S03 Reversal v11 Regime-ER using the shared Backtester V2 signal-reversal execution topology",
  "author": "",
  "execution": {
    "topology": "signal_reversal",
    "entryOrder": "market_next_open",
    "sizing": "fixed_pct_equity",
    "exitOnSignal": true,
    "target": "none",
    "trail": "none",
    "trailActivation": "none",
    "maxDays": false,
    "margin": "off",
    "boundary": "strict_close",
    "priceRounding": "none",
    "variantSelector": {
      "param": "useEmergencySL",
      "userFacing": false,
      "mapping": {
        "false": "plain",
        "true": "emergency"
      }
    },
    "variants": {
      "plain": {
        "stop": "none"
      },
      "emergency": {
        "stop": "emergency_pct"
      }
    }
  },
  "parameters": {
    "maType3": {
      "type": "select",
      "label": "T MA Type",
      "default": "SMA",
      "options": ["EMA", "SMA", "HMA", "WMA", "ALMA", "KAMA", "TMA", "T3", "DEMA", "VWMA", "VWAP"],
      "group": "Moving Averages",
      "role": "signal",
      "optimize": { "enabled": true }
    },
    "maLength3": {
      "type": "int",
      "label": "T MA Length",
      "default": 75,
      "min": 0,
      "max": 500,
      "step": 5,
      "group": "Moving Averages",
      "role": "signal",
      "optimize": { "enabled": true, "min": 25, "max": 500, "step": 25 }
    },
    "maOffset3": {
      "type": "float",
      "label": "T MA Offset %",
      "default": 0.2,
      "min": -10.0,
      "max": 10.0,
      "step": 0.5,
      "group": "Moving Averages",
      "role": "signal",
      "optimize": { "enabled": true, "default_enabled": false, "min": -2.0, "max": 2.0, "step": 0.5 }
    },
    "useCloseCount": {
      "type": "bool",
      "label": "Use Close Count",
      "default": true,
      "group": "Entry Filters",
      "role": "signal",
      "optimize": { "enabled": true }
    },
    "closeCountLong": {
      "type": "int",
      "label": "Close Count Long",
      "default": 7,
      "min": 1,
      "max": 50,
      "step": 1,
      "group": "Entry Filters",
      "role": "signal",
      "depends_on": "useCloseCount",
      "optimize": { "enabled": true, "min": 2, "max": 7, "step": 1 }
    },
    "closeCountShort": {
      "type": "int",
      "label": "Close Count Short",
      "default": 5,
      "min": 1,
      "max": 50,
      "step": 1,
      "group": "Entry Filters",
      "role": "signal",
      "depends_on": "useCloseCount",
      "optimize": { "enabled": true, "min": 2, "max": 7, "step": 1 }
    },
    "useTBands": {
      "type": "bool",
      "label": "Use T Bands",
      "default": true,
      "group": "Entry Filters",
      "role": "signal",
      "optimize": { "enabled": true }
    },
    "tBandLongPct": {
      "type": "float",
      "label": "T Band Long %",
      "default": 1.0,
      "min": 0.1,
      "max": 10.0,
      "step": 0.1,
      "group": "Entry Filters",
      "role": "signal",
      "depends_on": "useTBands",
      "optimize": { "enabled": true, "min": 0.2, "max": 2.0, "step": 0.2 }
    },
    "tBandShortPct": {
      "type": "float",
      "label": "T Band Short %",
      "default": 1.3,
      "min": 0.1,
      "max": 10.0,
      "step": 0.1,
      "group": "Entry Filters",
      "role": "signal",
      "depends_on": "useTBands",
      "optimize": { "enabled": true, "min": 0.2, "max": 2.0, "step": 0.2 }
    },
    "useRegime": {
      "type": "bool",
      "label": "Use Regime-ER",
      "default": true,
      "group": "Regime-ER",
      "role": "signal",
      "optimize": { "enabled": false }
    },
    "regimeErLength": {
      "type": "int",
      "label": "Regime ER Length",
      "default": 20,
      "min": 2,
      "max": 200,
      "step": 1,
      "group": "Regime-ER",
      "role": "signal",
      "depends_on": "useRegime",
      "optimize": { "enabled": true, "min": 20, "max": 40, "step": 10 }
    },
    "regimeErThresh": {
      "type": "float",
      "label": "Regime ER Threshold",
      "default": 0.3,
      "min": 0.01,
      "max": 1.0,
      "step": 0.01,
      "group": "Regime-ER",
      "role": "signal",
      "depends_on": "useRegime",
      "optimize": { "enabled": true, "min": 0.3, "max": 0.5, "step": 0.1 }
    },
    "initialCapital": {
      "type": "float",
      "label": "Initial Capital",
      "default": 100.0,
      "min": 0.01,
      "max": 1000000.0,
      "step": 1.0,
      "group": "Backtest Settings",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "commissionPct": {
      "type": "float",
      "label": "Commission (%)",
      "default": 0.05,
      "min": 0.0,
      "max": 1.0,
      "step": 0.01,
      "group": "Backtest Settings",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "positionPct": {
      "type": "float",
      "label": "Position Size (%)",
      "default": 100.0,
      "min": 0.01,
      "max": 100.0,
      "step": 1.0,
      "group": "Position Sizing",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "contractSize": {
      "type": "float",
      "label": "Contract Size",
      "default": 0.01,
      "min": 0.0001,
      "max": 1000000.0,
      "step": 0.0001,
      "group": "Position Sizing",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "enableLong": {
      "type": "bool",
      "label": "Enable Long",
      "default": true,
      "group": "Backtest Settings",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "enableShort": {
      "type": "bool",
      "label": "Enable Short",
      "default": true,
      "group": "Backtest Settings",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "useEmergencySL": {
      "type": "bool",
      "label": "Use Emergency SL",
      "default": false,
      "group": "Stops, Rewards, Risks",
      "role": "execution",
      "optimize": { "enabled": false }
    },
    "emergencySlPct": {
      "type": "float",
      "label": "Emergency SL %",
      "default": 20.0,
      "min": 10.0,
      "max": 20.0,
      "step": 10.0,
      "group": "Stops, Rewards, Risks",
      "role": "execution",
      "depends_on": "useEmergencySL",
      "optimize": { "enabled": true, "default_enabled": false, "min": 10.0, "max": 20.0, "step": 10.0 }
    },
    "emergencySlUpdateBars": {
      "type": "int",
      "label": "Emergency SL Update Bars",
      "default": 16,
      "min": 1,
      "max": 100,
      "step": 1,
      "group": "Stops, Rewards, Risks",
      "role": "execution",
      "depends_on": "useEmergencySL",
      "optimize": { "enabled": false }
    },
    "dateFilter": {
      "type": "bool",
      "label": "Date Filter",
      "default": true,
      "group": "Backtest Settings",
      "role": "runtime",
      "optimize": { "enabled": false }
    },
    "start": {
      "type": "datetime",
      "label": "Start",
      "default": null,
      "group": "Backtest Settings",
      "role": "runtime",
      "optimize": { "enabled": false }
    },
    "end": {
      "type": "datetime",
      "label": "End",
      "default": null,
      "group": "Backtest Settings",
      "role": "runtime",
      "optimize": { "enabled": false }
    },
    "warmupBars": {
      "type": "int",
      "label": "Warmup Bars",
      "default": 1000,
      "min": 0,
      "max": 5000,
      "step": 50,
      "group": "Backtest Settings",
      "role": "runtime",
      "optimize": { "enabled": false }
    }
  },
  "optimization_rules": {
    "bool_groups": [
      {
        "params": ["useCloseCount", "useTBands"],
        "mode": "at_least_one_true",
        "logical_modes": {
          "cc_only": {
            "values": { "useCloseCount": true, "useTBands": false },
            "label": "Close Count only"
          },
          "tbands_only": {
            "values": { "useCloseCount": false, "useTBands": true },
            "label": "T Bands only"
          },
          "both": {
            "values": { "useCloseCount": true, "useTBands": true },
            "label": "Both"
          }
        }
      }
    ]
  }
}
